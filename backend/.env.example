# Required backend app secrets
SECRET_KEY=                    # 32+ random bytes, run: openssl rand -hex 32
APP_ENV=development
DEBUG=false

# Required infrastructure
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/financeops
# Optional: direct Postgres URL for Alembic migrations (bypass pooler)
# Example: postgresql+asyncpg://postgres:<password>@db.<project>.supabase.co:5432/postgres
MIGRATION_DATABASE_URL=
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
REDIS_URL=redis://:password@localhost:6379/0
REDIS_PASSWORD=

# Required JWT signing
JWT_SECRET=                    # 32+ random bytes, different from SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Required field-level encryption
# Generate: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
FIELD_ENCRYPTION_KEY=

# Local docker-compose helper
POSTGRES_PASSWORD=

# Optional AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPEN_EXCHANGE_RATES_API_KEY=
EXCHANGE_RATE_API_KEY=

# Optional Cloudflare R2 storage
R2_ENDPOINT_URL=               # https://accountid.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=financeops-files

# Optional telemetry
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional Temporal / workflow runtime
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=financeops-default

# Optional payments
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Platform
PLATFORM_TIMEZONE=UTC
MAX_UPLOAD_SIZE_MB=100
SEED_ON_STARTUP=false

# Platform Owner Seed (run seed_platform_owner.py after setting these)
PLATFORM_OWNER_EMAIL=
PLATFORM_OWNER_PASSWORD=
PLATFORM_OWNER_NAME=

# Platform Admin Seed
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_NAME=
