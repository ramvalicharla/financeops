# App
SECRET_KEY=                    # 32+ random bytes, run: openssl rand -hex 32
APP_ENV=development
DEBUG=false

# Database — get from Railway PostgreSQL service
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/financeops
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis — get from Railway Redis service
REDIS_URL=redis://:password@localhost:6379/0
REDIS_PASSWORD=

# JWT
JWT_SECRET=                    # 32+ random bytes, different from SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# PostgreSQL credentials for docker-compose
POSTGRES_PASSWORD=

# AI Providers — all optional at Phase 0, required in Phase 4
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPEN_EXCHANGE_RATES_API_KEY=
EXCHANGE_RATE_API_KEY=

# Cloudflare R2 Storage
R2_ENDPOINT_URL=               # https://accountid.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=financeops-files

# Field-level encryption key — 32 bytes base64-encoded
# Generate: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
FIELD_ENCRYPTION_KEY=

# Telemetry — optional at Phase 0
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=financeops-default

# Payments — required in Phase 3
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Platform
PLATFORM_TIMEZONE=UTC
MAX_UPLOAD_SIZE_MB=100
