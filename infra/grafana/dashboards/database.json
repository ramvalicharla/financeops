{
  "uid": "finops-db",
  "title": "FinanceOps Database",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Active DB Connections",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(pg_stat_activity_count)", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Queries per Second",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [{ "expr": "rate(pg_stat_database_xact_commit[5m])", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Slow Queries (>1s)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [{ "expr": "sum(pg_stat_statements_slow_queries_total)", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Replication Lag",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "max(pg_replication_lag_seconds)", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Cache Hit Ratio",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "avg(pg_cache_hit_ratio)", "refId": "A" }]
    }
  ]
}

