{
  "uid": "finops-app",
  "title": "FinanceOps Application",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Celery Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "financeops_celery_queue_depth", "refId": "A" }]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Task Completion Rate",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "rate(celery_tasks_succeeded_total[5m])", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Task Failure Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "rate(celery_tasks_failed_total[5m])", "refId": "A" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Active Temporal Workflows",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum(temporal_workflow_active_total)", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Dead Letter Queue Count",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [{ "expr": "sum(celery_dead_letter_total)", "refId": "A" }]
    }
  ]
}

