{
  "description": "Finqor WAF Rules",
  "managed_rules": {
    "enabled": true
  },
  "rules": [
    {
      "id": "rate_limit_auth",
      "description": "Rate limit auth endpoints on api.finqor.ai",
      "expression": "(http.host eq \"api.finqor.ai\" and http.request.uri.path matches \"^/api/v1/auth/\")",
      "action": "challenge",
      "ratelimit": {
        "requests_per_period": 10,
        "period": 60,
        "mitigation_timeout": 600
      }
    },
    {
      "id": "rate_limit_api",
      "description": "Rate limit API endpoints on api.finqor.ai",
      "expression": "(http.host eq \"api.finqor.ai\" and http.request.uri.path matches \"^/api/\")",
      "action": "challenge",
      "ratelimit": {
        "requests_per_period": 100,
        "period": 60,
        "mitigation_timeout": 600
      }
    },
    {
      "id": "block_sql_injection",
      "description": "Block SQL injection attempts",
      "expression": "(cf.waf.score.sqli gt 40)",
      "action": "block"
    },
    {
      "id": "block_xss",
      "description": "Block XSS attempts",
      "expression": "(cf.waf.score.xss gt 40)",
      "action": "block"
    },
    {
      "id": "block_path_traversal",
      "description": "Block path traversal",
      "expression": "(http.request.uri.path contains \"../\")",
      "action": "block"
    },
    {
      "id": "challenge_admin_routes",
      "description": "Challenge admin routes",
      "expression": "(http.request.uri.path matches \"^/admin\")",
      "action": "managed_challenge"
    },
    {
      "id": "block_known_bad_bots",
      "description": "Block known malicious bots",
      "expression": "(cf.client.bot)",
      "action": "block"
    },
    {
      "id": "allow_health_checks",
      "description": "Allow health check endpoints unrestricted",
      "expression": "(http.request.uri.path eq \"/health\")",
      "action": "skip",
      "action_parameters": {
        "ruleset": "current"
      }
    }
  ]
}
