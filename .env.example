APP_NAME=FinanceOps
APP_ENV=development
DEBUG=false

# Backend auth and signing
SECRET_KEY=replace-with-random-secret
JWT_SECRET=replace-with-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend auth (NextAuth/Auth.js)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-random-nextauth-secret
# Optional fallback supported by frontend auth secret resolution
AUTH_SECRET=

POSTGRES_PASSWORD=replace-with-postgres-password
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/financeops
# Optional: direct Postgres URL for Alembic migrations (bypass pooler)
# Example: postgresql+asyncpg://postgres:<password>@db.<project>.supabase.co:5432/postgres
MIGRATION_DATABASE_URL=
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:password@localhost:6379/0

FIELD_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Frontend app
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_DOMAIN=localhost

# Optional AI integrations
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional workflow / storage integrations
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=financeops-default

R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=financeops-files

# Optional observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional payments
STRIPE_SECRET_KEY=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

PLATFORM_TIMEZONE=UTC
MAX_UPLOAD_SIZE_MB=100
SEED_ON_STARTUP=false

# Platform Owner Seed (run seed_platform_owner.py after setting these)
PLATFORM_OWNER_EMAIL=
PLATFORM_OWNER_PASSWORD=
PLATFORM_OWNER_NAME=

# Platform Admin Seed
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_NAME=
